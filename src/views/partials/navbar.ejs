<nav class="navbar navbar-dark bg-nav">
    <div class="container">
        <div class="nav-item d-flex align-items-center">
            <a class="navbar-brand" href="<%= subdir %>"><%= config.name %></a>      
            <div class="nav-item d-flex align-items-center">
                <% if (config.connect.show) { %>
                    <a href="<%= config.connect.url %>" class="btn btn-connect magnetic d-none d-md-inline-flex align-items-center">
                        <img src="<%= subdir %>icons/cs2.png" alt="" class="me-2">
                        <small><%= lang.connect %></small>
                    </a>
                <% } %>
            </div>
        </div>
        <div class="nav-item d-flex align-items-center">
            <!-- Language selector -->
            <div class="dropdown me-2" data-bs-theme="dark">
                <button class="btn btn-outline-primary" type="button" data-bs-toggle="dropdown" aria-expanded="false" title="<%= lang.language || 'Language' %>">
                    <i class="fa-solid fa-globe"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <% var langNames = { en: 'English', 'pt-BR': 'Português', ru: 'Русский', 'zh-CN': '简体中文' }; %>
                    <% availableLangs.forEach(function(code){ %>
                        <li><a class="dropdown-item<%= code === langCode ? ' active' : '' %>" href="<%= subdir %>api/lang/<%= code %>"><%= langNames[code] || code %></a></li>
                    <% }) %>
                </ul>
            </div>
            <% if (typeof user == 'undefined') { %>
                <%# Logged-out: the landing hero carries the Steam login button. %>
            <% } else { %>


                <div class="nav-item dropdown" data-bs-theme="dark">
                    <div class="profile-bg rounded p-1 px-2 d-flex align-items-center dropdown-toggle" role="button" data-bs-toggle="dropdown">
                        <p class="m-0 me-2"><small><%= user.displayName %></small></p>
                        <img src="<%= user.photos[1].value%>" alt="" height="30" class="rounded-pill">
                    </div>
                    <ul class="dropdown-menu">
                        <a class="dropdown-item text-danger" href="<%= subdir %>api/logout"><%= lang.navLogout %></a>
                        <a class="dropdown-item text-danger" href="<%= subdir %>api/delete"><%= lang.navDelete %></a>
                        <a class="dropdown-item text-warning d-block d-md-none" href="<%= config.connect.url %>"><small><%= lang.connect %></small></a>
                    </ul>
            <% } %>
        </div>
    </div>
</nav>
