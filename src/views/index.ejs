<%- include('./partials/header') %>
    
    <!-- Modal -->
    <div class="modal fade" id="patternFloat" tabindex="-1" aria-labelledby="patternFloatLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable">
            <div class="modal-content" style="background-color: transparent !important;">
                <div class="modal-header bg-nav text-light border-dark">
                    <h5 class="modal-title" id="patternFloatLabel"><%= lang.floatPattern %></h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body bg-color d-flex flex-column text-light">
                    <img id="modalImg" class="mx-auto" src="/images/econ/default_generated/weapon_knife_gut_hy_webs_light_png.png" width="40%">
                    <h5 class="mx-auto"><span id="modalWeapon">Gut knife</span> | <span id="modalPaint">Fade</span></h5>
                    <!-- Which side this edit applies to. Populated by editModal();
                         a single locked icon for team-exclusive guns. -->
                    <div class="d-flex justify-content-center align-items-center gap-2 mb-2">
                        <small class="text-secondary"><%= lang.applyTo %></small>
                        <div id="modalTeamSelector" class="d-flex align-items-center gap-2"></div>
                    </div>
                    <div class="form-outline mx-auto mb-2">
                        <label class="form-label m-0" for="float"><%= lang.float %></label>
                        <input type="range" id="floatSlider" class="slider" min="0" max="1" step="0.000001" value="0.000001" data-bs-theme="dark">
                        <input type="number" id="float" class="form-control" min="0" max="1" step="0.000001" value="0.000001" data-bs-theme="dark">
                        <p id="floatText" class="text-center m-0"><%= lang.factoryNew %></p>
                    </div>
                    <div class="btn-group mx-auto mb-2">
                        <button onclick="setFloat(0.0001)" class="btn btn-primary floatButton"><%= lang.factoryNewCode %></button>
                        <button onclick="setFloat(0.07)" class="btn btn-primary floatButton"><%= lang.minimalWearCode %></button>
                        <button onclick="setFloat(0.15)" class="btn btn-primary floatButton"><%= lang.fieldTestedCode %></button>
                        <button onclick="setFloat(0.38)" class="btn btn-primary floatButton"><%= lang.wellWornCode %></button>
                        <button onclick="setFloat(0.45)" class="btn btn-primary floatButton"><%= lang.battleScarredCode %></button>
                    </div>
                    <!-- Pattern + StatTrak share one row to use the space better. -->
                    <div class="modal-row mx-auto mt-3">
                        <div class="form-outline pattern-field">
                            <label class="form-label m-0" for="pattern"><%= lang.pattern %></label>
                            <input type="number" id="pattern" class="form-control" placeholder="<%= lang.pattern %>" value="0" data-bs-theme="dark">
                        </div>
                        <div class="form-check form-switch stattrak-field" id="stattrakWrapper">
                            <input class="form-check-input" type="checkbox" role="switch" id="stattrak">
                            <label class="form-check-label" for="stattrak"><%= lang.stattrak %></label>
                        </div>
                    </div>

                    <!-- Stickers: 4 slots, each with a per-slot wear slider. The
                         per-sticker placement editor (openStickerEditor) is kept
                         in the code but its button is hidden in the UI for now. -->
                    <div class="w-100 mt-4" id="stickerSection">
                        <div class="sticker-section-head">
                            <label class="form-label m-0"><%= lang.stickers %></label>
                            <button type="button" class="sticker-clear-all" onclick="clearAllSlots()"><i class="fa-solid fa-trash"></i> <%= lang.clearAll %></button>
                        </div>
                        <div class="d-flex justify-content-center flex-wrap gap-3 mt-2" id="stickerSlots">
                            <% for (let i = 0; i < 4; i++) { %>
                            <div class="sticker-slot" data-slot="<%= i %>">
                                <div class="sticker-thumb" onclick="openStickerPicker(<%= i %>)">
                                    <img id="stickerImg-<%= i %>" src="" alt="" class="sticker-img">
                                    <span id="stickerPlus-<%= i %>" class="sticker-plus"><i class="fa-solid fa-plus"></i></span>
                                    <button type="button" id="stickerApplyAll-<%= i %>" class="sticker-apply-all" title="<%= lang.applyToAll %>" style="display:none;" onclick="applyStickerToAll(event, <%= i %>)"><i class="fa-solid fa-clone"></i></button>
                                    <button type="button" id="stickerClear-<%= i %>" class="sticker-clear-badge" title="<%= lang.clear %>" style="display:none;" onclick="event.stopPropagation(); clearSticker(<%= i %>)"><i class="fa-solid fa-xmark"></i></button>
                                </div>
                                <!-- Placement editor button kept in code; hidden in the UI for now. -->
                                <button type="button" id="stickerPos-<%= i %>" class="sticker-pos" style="display:none;" onclick="openStickerEditor(<%= i %>)" title="<%= lang.position %>"><i class="fa-solid fa-up-down-left-right"></i></button>
                                <div class="sticker-wear-wrap" style="display:none;">
                                    <input type="range" id="stickerWear-<%= i %>" class="slider sticker-wear" min="0" max="1" step="0.01" value="0" oninput="onStickerWearInput(<%= i %>)">
                                    <small class="sticker-wear-label"><%= lang.stickerWear %> <span id="stickerWearVal-<%= i %>">0.00</span></small>
                                </div>
                            </div>
                            <% } %>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-nav text-light border-dark d-flex justify-content-center">
                    <button type="button" class="btn btn-outline-primary" onclick="changeParams()" id="modalButton"><%= lang.change %></button>
                </div>
            </div>
        </div>

        <!-- Sticker picker overlay. Kept INSIDE #patternFloat (sibling of the
             modal-dialog) so Bootstrap's focus-trap treats it as in-modal and
             lets the search field receive keystrokes; position:fixed makes it
             cover the whole viewport regardless of the parent. -->
        <div id="stickerPicker" class="sticker-picker-overlay" onclick="onStickerOverlayClick(event)">
            <div class="sticker-picker-dialog bg-color text-light">
                <div class="sticker-picker-header bg-nav">
                    <h5 class="m-0"><%= lang.selectSticker %> <span id="stickerPickerSlotLabel" class="text-secondary"></span></h5>
                    <button type="button" class="btn-close btn-close-white" onclick="closeStickerPicker()" aria-label="Close"></button>
                </div>
                <div class="sticker-picker-body">
                    <!-- Filter bar. Every dropdown (competition / collection / org /
                         player / type / effect / rarity) is a custom type-ahead input:
                         type to filter or pick from the dropdown built in index.js.
                         They cascade (picking a competition narrows collection/org/
                         player, picking an org narrows players). -->
                    <!-- The free-text search (type to match any sticker name) is
                         visually separated from the structured dropdown filters
                         below: it spans the full width, carries a search icon and
                         an accent border, so it never reads like the comboboxes. -->
                    <div class="sticker-search-wrap mb-2">
                        <i class="fa-solid fa-magnifying-glass sticker-search-icon"></i>
                        <input type="text" id="stickerSearch" class="form-control sticker-search-input" placeholder="<%= lang.searchStickers %>" oninput="onStickerSearchInput()" data-bs-theme="dark" autocomplete="off">
                    </div>
                    <div class="row g-2 mb-3 sticker-filter-bar">
                        <div class="col-6 col-md-auto sticker-ta">
                            <input type="text" id="stickerFilterComp" class="form-control sticker-combo" placeholder="<%= lang.allCompetitions %>" oninput="onStickerCompInput()" data-bs-theme="dark" autocomplete="off">
                        </div>
                        <div class="col-6 col-md-auto sticker-ta">
                            <input type="text" id="stickerFilterColl" class="form-control sticker-combo" placeholder="<%= lang.filterColl %>" oninput="onStickerCollInput()" data-bs-theme="dark" autocomplete="off">
                        </div>
                        <div class="col-6 col-md-auto sticker-ta">
                            <input type="text" id="stickerFilterOrg" class="form-control sticker-combo" placeholder="<%= lang.filterOrg %>" oninput="onStickerOrgInput()" data-bs-theme="dark" autocomplete="off">
                        </div>
                        <div class="col-6 col-md-auto sticker-ta">
                            <input type="text" id="stickerFilterPlayer" class="form-control sticker-combo" placeholder="<%= lang.filterPlayer %>" oninput="onStickerPlayerInput()" data-bs-theme="dark" autocomplete="off">
                        </div>
                        <div class="col-6 col-md-auto sticker-ta">
                            <input type="text" id="stickerFilterType" class="form-control sticker-combo" placeholder="<%= lang.allTypes %>" oninput="onStickerTypeInput()" data-bs-theme="dark" autocomplete="off">
                        </div>
                        <div class="col-6 col-md-auto sticker-ta">
                            <input type="text" id="stickerFilterEffect" class="form-control sticker-combo" placeholder="<%= lang.allEffects %>" oninput="onStickerEffectInput()" data-bs-theme="dark" autocomplete="off">
                        </div>
                        <div class="col-6 col-md-auto sticker-ta">
                            <input type="text" id="stickerFilterRarity" class="form-control sticker-combo" placeholder="<%= lang.allRarities %>" oninput="onStickerRarityInput()" data-bs-theme="dark" autocomplete="off">
                        </div>
                        <div class="col-6 col-md-auto d-flex align-items-center gap-2">
                            <button type="button" id="stickerFilterReset" class="btn btn-sm btn-outline-secondary" onclick="resetStickerFilters()"><%= lang.resetFilters %></button>
                            <small class="text-secondary" id="stickerResultCount"></small>
                        </div>
                    </div>
                    <div id="stickerResults" class="sticker-results-grid"></div>
                </div>
            </div>
        </div>

        <!-- 2D sticker placement editor. Sibling of #stickerPicker (inside
             #patternFloat) so it sits above the modal and covers the viewport.
             The current skin image is stretched into a per-weapon canvas; each
             sticker is dragged on it and its placement maps to the game's
             offset_x/offset_y so it matches in-game. -->
        <div id="sticker2dEditor" class="sticker2d-overlay">
            <div class="sticker2d-dialog bg-color text-light">
                <div class="sticker2d-header bg-nav">
                    <h5 class="m-0"><%= lang.positionTitle %> <span id="sticker2dSlotLabel" class="text-secondary"></span></h5>
                    <button type="button" class="btn-close btn-close-white" onclick="closeStickerEditor()" aria-label="Close"></button>
                </div>
                <div class="sticker2d-body">
                    <div id="sticker2dStage" class="sticker2d-stage">
                        <div id="sticker2dCanvas" class="sticker2d-canvas">
                            <img id="sticker2dBg" class="sticker2d-bg" alt="" draggable="false">
                        </div>
                    </div>
                    <div class="sticker2d-side">
                        <div class="sticker2d-legend small text-secondary mb-2"><%= lang.positionHelp %></div>
                        <div id="sticker2dStatus" class="small mb-3"></div>

                        <label class="form-label small mb-1"><%= lang.rotation %>: <span id="sticker2dRotVal">0&deg;</span></label>
                        <input type="range" id="sticker2dRot" class="slider w-100" min="0" max="360" step="1" value="0">

                        <label class="form-label small mb-1 mt-3"><%= lang.defaultSlots %></label>
                        <div class="btn-group btn-group-sm w-100" role="group">
                            <button type="button" class="btn btn-outline-light" onclick="placeSelectedAtSlot(0)">1</button>
                            <button type="button" class="btn btn-outline-light" onclick="placeSelectedAtSlot(1)">2</button>
                            <button type="button" class="btn btn-outline-light" onclick="placeSelectedAtSlot(2)">3</button>
                            <button type="button" class="btn btn-outline-light" onclick="placeSelectedAtSlot(3)">4</button>
                        </div>

                        <button type="button" class="btn btn-sm btn-outline-danger w-100 mt-3" onclick="clearAllStickers()"><i class="fa-solid fa-trash"></i> <%= lang.clearAll %></button>

                        <div class="mt-auto d-flex gap-2 flex-wrap pt-3">
                            <button type="button" class="btn btn-sm btn-outline-light" onclick="resetStickerEditor()"><%= lang.reset %></button>
                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="closeStickerEditor()"><%= lang.cancel %></button>
                            <button type="button" class="btn btn-sm btn-primary ms-auto" onclick="saveStickerEditor()"><%= lang.save %></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Inspect link modal -->
    <div class="modal fade" id="inspectModal" tabindex="-1" aria-labelledby="inspectModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content text-light" style="background-color: transparent !important;">
                <div class="modal-header bg-nav border-dark">
                    <h5 class="modal-title" id="inspectModalLabel"><%= lang.inspectTitle %></h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body bg-color">
                    <p class="text-secondary"><small><%= lang.inspectDesc %></small></p>
                    <textarea id="inspectInput" class="form-control" rows="4" placeholder="<%= lang.inspectPlaceholder %>" data-bs-theme="dark"></textarea>
                    <p id="inspectStatus" class="m-0 mt-2"></p>
                </div>
                <div class="modal-footer bg-nav text-light border-dark d-flex justify-content-center">
                    <button type="button" class="btn btn-outline-primary" id="inspectButton" onclick="applyInspectLink()"><%= lang.inspectApply %></button>
                </div>
            </div>
        </div>
    </div>


    <!-- Import / Export loadout modal -->
    <div class="modal fade" id="shareModal" tabindex="-1" aria-labelledby="shareModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content share-modal text-light">
                <div class="modal-header">
                    <h5 class="modal-title d-flex align-items-center" id="shareModalLabel"><i class="fa-solid fa-right-left me-2 text-accent"></i><%= lang.shareTitle %></h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <!-- Export: one click copies the code to the clipboard, no code shown. -->
                    <div class="share-card">
                        <div class="share-card-head">
                            <span class="share-card-icon"><i class="fa-solid fa-up-right-from-square"></i></span>
                            <div>
                                <h6><%= lang.shareExportHead %></h6>
                                <small class="text-secondary"><%= lang.shareExportDesc %></small>
                            </div>
                        </div>
                        <button type="button" id="shareCopyBtn" class="btn btn-accent w-100 share-copy-btn" onclick="copyShareCode()">
                            <i class="fa-solid fa-copy me-2"></i><span id="shareCopyLabel"><%= lang.shareCopy %></span>
                        </button>
                        <!-- Only revealed if the clipboard write fails (non-secure context): the
                             code is shown here, pre-selected, for the user to copy by hand. -->
                        <input type="text" id="shareExportCode" class="form-control share-textarea mt-2" readonly style="display:none;" onclick="this.select()" data-bs-theme="dark">
                    </div>

                    <!-- Import: paste a code and apply it. -->
                    <div class="share-card">
                        <div class="share-card-head">
                            <span class="share-card-icon"><i class="fa-solid fa-file-import"></i></span>
                            <div>
                                <h6><%= lang.shareImportHead %></h6>
                                <small class="text-secondary"><%= lang.shareImportDesc %></small>
                            </div>
                        </div>
                        <textarea id="shareImportCode" class="form-control share-textarea" rows="2" placeholder="<%= lang.shareImportPlaceholder %>" data-bs-theme="dark"></textarea>
                        <p id="shareStatus" class="m-0 mt-2 small"></p>
                        <div class="d-flex gap-2 mt-2">
                            <button type="button" class="btn btn-outline-light flex-shrink-0" onclick="pasteShareCode()">
                                <i class="fa-solid fa-paste me-2"></i><%= lang.sharePaste %>
                            </button>
                            <button type="button" class="btn btn-accent flex-grow-1" id="shareImportBtn" onclick="applyShareCode()">
                                <i class="fa-solid fa-wand-magic-sparkles me-2"></i><%= lang.shareImport %>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <%- include('./partials/navbar') %>

    <% if (typeof user == 'undefined') { %>
        <div class="login-hero d-flex flex-column align-items-center justify-content-center text-center text-light px-3">
            <i class="bi bi-steam login-hero-logo mb-3"></i>
            <h1 class="login-hero-title mb-2"><%= config.name %></h1>
            <p class="text-secondary login-hero-sub mb-4"><%= lang.loginTagline || lang.needLogin %></p>
            <a class="btn btn-steam btn-lg d-inline-flex align-items-center" href="<%= subdir %>api/auth/steam">
                <i class="bi bi-steam me-2"></i><%= lang.navLogin %> <%= lang.viaSteam %>
            </a>
        </div>
    <% } else { %>

    <div class="container text-light mt-3">
        <div class="sidebar-search mb-2 d-block d-lg-none">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text" id="globalSkinSearchMobile" class="form-control" placeholder="<%= lang.sideMenu.search %>" oninput="runSkinSearch(this.value)" autocomplete="off" data-bs-theme="dark">
        </div>
        <div class="d-block d-lg-none list-group list-group-horizontal position-relative overflow-auto d-flex justify-content-between bg-nav p-2 rounded">
            <button onclick="showLoadout()" id="sideBtnLoadout" class="btn btn-outline-primary d-flex my-1 mx-1 align-items-center">
                <i class="fa-solid fa-layer-group ms-1 me-2 my-auto"></i>
                <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.loadout %></small></p>
            </button>

            <button onclick="showKnives()" id="sideBtnKnives" class="btn btn-outline-primary d-flex my-1 mx-1 align-items-center" data-type="sideBtn" data-btn-type="knives">
                <img src="icons/weapon_knife_karambit.svg" style="filter: invert();" width="35px">
                <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.knives %></small></p>
            </button>

            <button onclick="showGloves()" id="sideBtnGloves" class="btn btn-outline-primary d-flex my-1 mx-1 align-items-center" data-type="sideBtn" data-btn-type="gloves">
                <i class="fa-solid fa-mitten ms-1 me-2 my-auto"></i>
                <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.gloves %></small></p>
            </button>

            <button onclick="showMusics()" id="sideBtnMusics" class="btn btn-outline-primary d-flex my-1 mx-1 align-items-center" data-type="sideBtn" data-btn-type="musics">
                <i class="fa-solid fa-music ms-1 me-2 my-auto"></i>
                <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.musics %></small></p>
            </button>


            <button onclick="showPistols()" id="sideBtnPistols" class="btn btn-outline-primary d-flex my-1 mx-1 align-items-center" data-type="sideBtn" data-btn-type="pistols">
                <img src="icons/weapon_deagle.svg" style="filter: invert();" width="35px">
                <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.pistols %></small></p>
            </button>

            <button onclick="showRifles()" id="sideBtnRifles" class="btn btn-outline-primary d-flex my-1 mx-1 align-items-center" data-type="sideBtn" data-btn-type="rifles">
                <img src="icons/weapon_ak47.svg" style="filter: invert();" width="35px">
                <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.rifles %></small></p>
            </button>

            <button onclick="showPPs()" id="sideBtnPPs" class="btn btn-outline-primary d-flex my-1 mx-1 align-items-center" data-type="sideBtn" data-btn-type="smgs">
                <img src="icons/weapon_mac10.svg" style="filter: invert();" width="35px">
                <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.SMGs %></small></p>
            </button>

            <button onclick="showShotguns()" id="sideBtnShotguns" class="btn btn-outline-primary my-1 mx-1 d-flex align-items-center" data-type="sideBtn" data-btn-type="heavy">
                <img src="icons/weapon_negev.svg" style="filter: invert();" width="35px">
                <p class="p-0 m-0 mx-auto"><small><%= lang.sideMenu.heavy %></small></p>
            </button>

            <button type="button" class="btn btn-outline-primary my-1 mx-1 d-flex align-items-center" data-bs-toggle="modal" data-bs-target="#inspectModal">
                <i class="fa-solid fa-link ms-1 me-2 my-auto"></i>
                <p class="p-0 m-0 mx-auto"><small><%= lang.inspectBtn %></small></p>
            </button>
        </div>
        <div class="row">
            <div class="col-2 rounded p-0 d-none d-lg-block">
                <div class="sticky-top" style="top: 10px;">
                    <div class="bg-nav rounded p-0 p-2 pb-0">
                        <button class="pushable" onclick="showLoadout()">
                            <span class="shadow"></span>
                            <span class="edge"></span>
                            <div class="front d-flex" id="sideBtnLoadout">
                                    <i class="fa-solid fa-layer-group ms-3 me-2 my-auto"></i>
                                    <p class="m-0 mx-auto"><%= lang.sideMenu.loadout %></p>
                            </div>
                        </button>

                        <div class="sidebar-search mb-2">
                            <i class="fa-solid fa-magnifying-glass"></i>
                            <input type="text" id="globalSkinSearch" class="form-control" placeholder="<%= lang.sideMenu.search %>" oninput="runSkinSearch(this.value)" autocomplete="off" data-bs-theme="dark">
                        </div>

                        <button class="pushable" onclick="showKnives()" data-type="sideBtn" data-btn-type="knives">
                            <span class="shadow"></span>
                            <span class="edge"></span>
                            <div class="front d-flex" id="sideBtnKnives">
                                    <img src="icons/weapon_knife_karambit.svg" class="ms-2" style="filter: invert();" width="35px">
                                    <p class="m-0 mx-auto"><%= lang.sideMenu.knives %></p>
                            </div>
                        </button>

                        <button class="pushable" onclick="showGloves()" data-type="sideBtn" data-btn-type="gloves">
                            <span class="shadow"></span>
                            <span class="edge"></span>
                            <div class="front d-flex" id="sideBtnGloves">
                                    <i class="fa-solid fa-mitten ms-3 me-2 my-auto"></i>
                                    <p class="m-0 mx-auto"><%= lang.sideMenu.gloves %></p>                 
                            </div>
                        </button>

                        <button class="pushable" onclick="showMusics()" data-type="sideBtn" data-btn-type="musics">
                            <span class="shadow"></span>
                            <span class="edge"></span>
                            <div class="front d-flex" id="sideBtnMusics">
                                    <i class="fa-solid fa-music ms-3 me-2 my-auto"></i>
                                    <p class="m-0 mx-auto"><%= lang.sideMenu.musics %></p>                 
                            </div>
                        </button>

                        <button class="pushable" onclick="showPistols()" data-type="sideBtn" data-btn-type="pistols">
                            <span class="shadow"></span>
                            <span class="edge"></span>
                            <div class="front d-flex" id="sideBtnPistols">
                                    <img src="icons/weapon_deagle.svg" class="ms-2" style="filter: invert();" width="35px">
                                    <p class="m-0 mx-auto"><%= lang.sideMenu.pistols %></p>                 
                            </div>
                        </button>

                        <button class="pushable" onclick="showRifles()" data-type="sideBtn" data-btn-type="rifles">
                            <span class="shadow"></span>
                            <span class="edge"></span>
                            <div class="front d-flex" id="sideBtnRifles">
                                    <img src="icons/weapon_ak47.svg" class="ms-2" style="filter: invert();" width="35px">
                                    <p class="m-0 mx-auto"><%= lang.sideMenu.rifles %></p>                 
                            </div>
                        </button>
        
                        <button class="pushable" onclick="showPPs()" data-type="sideBtn" data-btn-type="smgs">
                            <span class="shadow"></span>
                            <span class="edge"></span>
                            <div class="front d-flex" id="sideBtnPPs">
                                    <img src="icons/weapon_mac10.svg" class="ms-2" style="filter: invert();" width="35px">
                                    <p class="m-0 mx-auto"><%= lang.sideMenu.SMGs %></p>                 
                            </div>
                        </button>

                        <button class="pushable" onclick="showShotguns()" data-type="sideBtn" data-btn-type="heavy">
                            <span class="shadow"></span>
                            <span class="edge"></span>
                            <div class="front d-flex" id="sideBtnShotguns">
                                    <img src="icons/weapon_negev.svg" class="ms-2" style="filter: invert();" width="35px">
